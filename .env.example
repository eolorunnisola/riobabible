# Get a key at https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase — riobabible (Console → Project settings → Your apps → Web app)
# Enable Authentication → Sign-in method → Email/Password
# Create Firestore (production mode) then deploy rules: npm run firebase:deploy
EXPO_PUBLIC_FIREBASE_API_KEY=your_web_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=riobabible.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=riobabible
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=riobabible.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=379761857091
EXPO_PUBLIC_FIREBASE_APP_ID=1:379761857091:web:7d5ce878285445ff88faf6

# RevenueCat — public SDK keys (Dashboard → Project → API keys → "App specific keys")
# These are public client keys (safe to ship). iOS keys start with "appl_", Android with "goog_".
# Without these the app falls back to a non-purchasing mock.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_ios_sdk_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_android_sdk_key_here
